LISTEN_ADDR=:8080
MYSQL_DSN=user:pass@tcp(127.0.0.1:3306)/noteapi?parseTime=true&loc=Local
JWT_SECRET=change-me-to-long-random

WECHAT_APP_ID=wx...
WECHAT_APP_SECRET=...

# 华为帐号 OAuth（Harmony 登录；与 AGC 一致）
HUAWEI_CLIENT_ID=
HUAWEI_CLIENT_SECRET=
HUAWEI_REDIRECT_URI=

# Sign in with Apple（identity_token 校验）
APPLE_CLIENT_ID=

# 轻羽 NAS WebDAV（必填才能在服务端下发；使用 deployment secret，勿把真实值提交仓库）
QINGYU_WEBDAV_BASE_URL=https://nas.example.com:5006/QingYuYun
QINGYU_WEBDAV_USERNAME=
QINGYU_WEBDAV_PASSWORD=

PUBLIC_BASE_URL=https://noteapi.kymjs.com

# 商户就绪后填写（APP 支付 APIv3）
WECHAT_PAY_MCH_ID=
WECHAT_PAY_CERT_SERIAL=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_API_V3_KEY=

# 微信平台证书 PEM（用于回调验签），可从商户平台或 /v3/certificates 获取
WECHAT_PAY_PLATFORM_CERT_PEM_PATH=

WECHAT_PAY_NOTIFY_PATH=/api/v1/webhooks/wechat/pay
