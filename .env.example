LISTEN_ADDR=:9443
MYSQL_DSN=user:pass@tcp(127.0.0.1:3306)/noteapi?parseTime=true&loc=Local
JWT_SECRET=change-me-to-long-random

# 可选：除 stderr 外追加写入日志文件（systemd/docker 仍会采集 stderr；文件需配合 logrotate 防撑盘）
# LOG_FILE=/var/log/noteapi.log

WECHAT_APP_ID=wx...
WECHAT_APP_SECRET=...

# 华为帐号 OAuth（Harmony 登录；与 AGC 一致）
HUAWEI_CLIENT_ID=
HUAWEI_CLIENT_SECRET=
HUAWEI_REDIRECT_URI=

# Sign in with Apple（校验 identity_token 的 aud）
# iOS 原生 App：aud 为 Xcode 的 Bundle ID（本仓库 Flutter iOS 示例：com.kymjs.note）
# 网页 Sign in with Apple：aud 为 Apple Developer 里的 Services ID
# 多个允许值用英文逗号分隔，例如：com.kymjs.note,your.services.id
APPLE_CLIENT_ID=

# iOS 微信 Universal Link（https://noteapi.kymjs.com/wx/login/）：供 /.well-known/apple-app-site-association 生成 appID；见 DEPLOYMENT.md
APPLE_APP_SITE_ASSOCIATION_TEAM_ID=

# App Store 内购（iOS 上报 StoreKit JWS 由 POST /api/v1/orders/{id}/apple/verify 校验）
# 商品 ID 须与 App Store Connect、Flutter dart-define 一致；证书链校验依赖仓库内 internal/appstoreiap/AppleRootCA-G3.cer
APPLE_IAP_BUNDLE_ID=com.kymjs.note
APPLE_IAP_PRODUCT_MONTHLY=com.kymjs.note.qingyu.monthly
APPLE_IAP_PRODUCT_HALF_YEAR=com.kymjs.note.qingyu.half_year
APPLE_IAP_PRODUCT_YEARLY=com.kymjs.note.qingyu.yearly
# App Store Connect → App 信息 → Apple ID（数字）；Production JWS 校验需要；仅沙盒时可暂缓
APPLE_APP_STORE_APP_ID=

# 轻羽 NAS WebDAV（必填才能在服务端下发；使用 deployment secret，勿把真实值提交仓库）
QINGYU_WEBDAV_BASE_URL=https://nas.example.com:5006/QingYuYun
QINGYU_WEBDAV_USERNAME=
QINGYU_WEBDAV_PASSWORD=

# 用户头像：WebDAV 上传到 NAS（路径示例），对外 CDN 域名写入 avatar_url；凭据请换为真实值
AVATAR_WEBDAV_BASE_URL=https://nas.therouter.cn:5006/cdn/note-avatar
AVATAR_WEBDAV_USERNAME=placeholder_username
AVATAR_WEBDAV_PASSWORD=placeholder_password
AVATAR_PUBLIC_BASE_URL=https://cdn.kymjs.com:8843/note-avatar

PUBLIC_BASE_URL=https://noteapi.kymjs.com

# 商户就绪后填写（APP 支付 APIv3）
WECHAT_PAY_MCH_ID=
WECHAT_PAY_CERT_SERIAL=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_API_V3_KEY=

# 微信平台证书 PEM（用于回调验签），可从商户平台或 /v3/certificates 获取
WECHAT_PAY_PLATFORM_CERT_PEM_PATH=

WECHAT_PAY_NOTIFY_PATH=/api/v1/webhooks/wechat/pay

# ---------------------------------------------------------------------------
# 阿里云号码认证 — 短信验证码（Dypnsapi 2017-05-25）
# 用于：POST /api/v1/me/password/sms/send（SendSmsVerifyCode，需登录，与旧客户端兼容）
#      POST /api/v1/password/reset/sms/send（公开：按手机号发重置密码验证码）
#      POST /api/v1/me/profile/phone/sms/send（向目标号发码，用于资料页绑定/改号）
#      PATCH /api/v1/me/profile 带 sms_verify_code（CheckSmsVerifyCode，以 Model.VerifyResult=PASS 为准）
#      POST /api/v1/password/reset（公开：短信核验后重置该手机号对应账号密码）
# RAM 须授权：dypns:SendSmsVerifyCode、dypns:CheckSmsVerifyCode
# 控制台：赠送签名与赠送模板须配对；TemplateParam 使用 {"code":"##code##",...} 时由 API 发码并可核验
# ALIYUN_SMS_SCHEME_NAME：若发送时非空，核验（Check）须传相同方案名
#
# 若客户端提示「阿里云密钥或权限」：多为 AK/SK 错误、RPC 签名失败或 RAM 未授权。
# - RAM 自定义策略示例（Action 含 send + check）：见阿里云文档「号码认证」API 授权表。
# - Secret 与控制台 AccessKey 对应；复制时勿多空格/换行。
# - 若实为「签名/模板」问题，部署新版服务端后 Toast 会改为「签名或模板与控制台不一致」。
# ---------------------------------------------------------------------------
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_REGION=cn-hangzhou
# 赠送签名名称（与号码认证/短信认证控制台「赠送签名」一致）
ALIYUN_SMS_SIGN_NAME=速通互联验证码
# 赠送模板 CODE（与赠送签名搭配）
ALIYUN_SMS_TEMPLATE_CODE=100001
# 可选；默认方案可留空。非空时须与发送接口 SchemeName 一致
ALIYUN_SMS_SCHEME_NAME=
# 与模板变量一致，JSON 字符串；默认与动态验证码占位符示例
ALIYUN_SMS_TEMPLATE_PARAM={"code":"##code##","min":"5"}

# 兑换码签发工具 cmd/issue_redemption_codes：须与命令行 -issuer-secret 一致（勿泄露）
REDEMPTION_ISSUE_SECRET=

# 签发脚本每张兑换码单独 POST 到飞书群机器人 Webhook（可选）
FEISHU_REDEMPTION_WEBHOOK_URL=
