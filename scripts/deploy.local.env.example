# ---------------------------------------------------------------------------
# 复制本文件为同目录下的 deploy.local.env 后填写真实值（勿提交到 Git）：
#   cp scripts/deploy.local.env.example scripts/deploy.local.env
#   chmod 600 scripts/deploy.local.env
# deploy.sh 启动时会自动 source deploy.local.env（若存在）。
# ---------------------------------------------------------------------------

# ---------- 可选：覆盖脚本默认值 ----------
# DEPLOY_ROOT=/opt/noteapi
# ENV_FILE=/etc/noteapi.env
# SERVICE_NAME=noteapi
# update 成功后对本机监听地址做 health 冒烟（与 LISTEN_ADDR 一致；仅当 noteapi 监听本机时可访问）
# NOTEAPI_HEALTH_URL=http://127.0.0.1:9443/healthz

# 追加文件日志（供运行中的 noteapi 读取）：写在 systemd 的 EnvironmentFile 里（默认与 ENV_FILE 相同，即 /etc/noteapi.env），不要用 deploy.local.env 代替——后者只给本脚本 source，不会传给 systemd。
# 在服务器上编辑 sudo nano /etc/noteapi.env，取消注释或新增一行，例如：
# LOG_FILE=/var/log/noteapi.log
# first-time / update / rollback 会根据该行自动创建目录与空日志文件。

# Go 拉模块仍超时时可改（或 export 后执行 deploy.sh）：
# GOPROXY=https://goproxy.io,direct
# GOSUMDB=off

# ---------- 供「migrate」与「update（RUN_MIGRATE_ON_UPDATE=1）」自动执行 SQL（推荐填写）----------
# 若留空，请继续在服务器上手工执行 migrations/*.sql（含 004_redemption_codes.sql）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=noteapi
MYSQL_PASSWORD=
MYSQL_DATABASE=noteapi

# ---------- 与运行 noteapi 时使用的 MYSQL_DSN 一致（写入 ENV_FILE 的那份）----------
# 脚本不会在仓库里保存此处密码；仅在你本机 deploy.local.env 填写。
# MYSQL_DSN='noteapi:密码@tcp(127.0.0.1:3306)/noteapi?parseTime=true&loc=Local'

# ---------- 用户头像（WebDAV + CDN，与 .env 中 AVATAR_* 一致，部署时一并写入服务环境）----------
# AVATAR_WEBDAV_BASE_URL=https://nas.therouter.cn:5006/cdn/note-avatar
# AVATAR_WEBDAV_USERNAME=
# AVATAR_WEBDAV_PASSWORD=
# AVATAR_PUBLIC_BASE_URL=http://cdn.kymjs.com:8843/note-avatar
